#!/usr/bin/env bash
#
# pre-commit — council-pipeline provenance gate (harness Gap 1 + Gap 4).
#
# This hook lives in .githooks/ (version-controlled) so every fresh clone inherits
# the gate automatically. Git is wired via:
#
#     git config core.hooksPath .githooks
#
# The check logic lives in scripts/check-council-stamp.sh (also committed).
#
set -uo pipefail

# --- only-Gaffer-commits guard (harness Q6) --------------------------------
# All automated commits must be serialised through scripts/git_commit_safe.sh,
# which sets COUNCIL_COMMIT_AUTHORIZED=1. A raw `git commit` (e.g. a council agent
# committing directly and racing the git index) carries no marker and is blocked.
# Human escape hatch: `git commit --no-verify` (bypasses all hooks, by design).
if [ "${COUNCIL_COMMIT_AUTHORIZED:-0}" != "1" ]; then
  echo "pre-commit: direct commits are disabled (only-Gaffer-commits protocol)." >&2
  echo "  Route the commit through scripts/git_commit_safe.sh — it serialises on the" >&2
  echo "  git lock and authorises the commit. Human override: git commit --no-verify." >&2
  exit 1
fi
# ---------------------------------------------------------------------------

REPO_ROOT="$(git rev-parse --show-toplevel)"
CHECK_SCRIPT="$REPO_ROOT/scripts/check-council-stamp.sh"

# Staged Markdown files only. The check script decides which ones require a stamp.
# If nothing Markdown is staged, the council-stamp gate is irrelevant to this commit
# — proceed regardless of whether the check script is present.
staged_md="$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)"

if [ -z "$staged_md" ]; then
  exit 0
fi

# There ARE Markdown files to gate. From here the gate MUST be able to run — an
# enforcement hook that cannot run its check must fail CLOSED, never wave commits through.
if [ -z "$REPO_ROOT" ]; then
  echo "pre-commit: could not resolve repo root (git rev-parse failed) — BLOCKING commit (fail-closed)." >&2
  exit 1
fi

if [ ! -x "$CHECK_SCRIPT" ]; then
  echo "pre-commit: council-stamp check script missing or not executable at $CHECK_SCRIPT." >&2
  echo "  BLOCKING commit (fail-closed): an enforcement gate that cannot run must not wave commits through." >&2
  echo "  Restore the script, or human override with: git commit --no-verify." >&2
  exit 1
fi

printf '%s\n' "$staged_md" | "$CHECK_SCRIPT"
